{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:plan-orchestrator:schema:supervision_heartbeat.v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "supervisor_session_id",
    "kernel_invocation_id",
    "heartbeat_sequence",
    "observed_at_utc",
    "claim_class",
    "freshness_policy",
    "kernel_snapshot",
    "probe_evidence",
    "active_stage",
    "diagnosis_snapshot",
    "rejection_reason",
    "latest_intervention_path"
  ],
  "properties": {
    "schema_version": {
      "const": "plan_orchestrator.supervision_heartbeat.v1"
    },
    "run_id": {
      "$ref": "#/$defs/identifier"
    },
    "supervisor_session_id": {
      "$ref": "#/$defs/identifier"
    },
    "kernel_invocation_id": {
      "$ref": "#/$defs/non_empty_string"
    },
    "heartbeat_sequence": {
      "type": "integer",
      "minimum": 1
    },
    "observed_at_utc": {
      "type": "string",
      "format": "date-time"
    },
    "claim_class": {
      "enum": [
        "live_attached",
        "waiting_state_observed",
        "attachment_unproven",
        "terminal_observed",
        "snapshot_only"
      ]
    },
    "freshness_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "live_probe_interval_sec",
        "probe_ack_deadline_sec",
        "live_stale_timeout_sec",
        "waiting_poll_interval_sec",
        "waiting_stale_timeout_sec"
      ],
      "properties": {
        "live_probe_interval_sec": {
          "type": "integer",
          "minimum": 1
        },
        "probe_ack_deadline_sec": {
          "type": "integer",
          "minimum": 1
        },
        "live_stale_timeout_sec": {
          "type": "integer",
          "minimum": 1
        },
        "waiting_poll_interval_sec": {
          "type": "integer",
          "minimum": 1
        },
        "waiting_stale_timeout_sec": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "kernel_snapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "run_state_path",
        "run_state_sha256",
        "current_state",
        "current_item_id",
        "current_terminal_state",
        "run_state_updated_at_utc"
      ],
      "properties": {
        "run_state_path": {
          "$ref": "#/$defs/non_empty_string"
        },
        "run_state_sha256": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^[a-f0-9]{64}$"
        },
        "current_state": {
          "type": [
            "string",
            "null"
          ]
        },
        "current_item_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "current_terminal_state": {
          "type": [
            "string",
            "null"
          ]
        },
        "run_state_updated_at_utc": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        }
      }
    },
    "probe_evidence": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": false,
      "required": [
        "probe_sequence",
        "probe_nonce",
        "probe_request_issued_at_utc",
        "probe_request_expires_at_utc",
        "probe_ack_at_utc",
        "bridge_registration_path",
        "bridge_registration_sha256",
        "probe_request_sha256",
        "probe_ack_sha256"
      ],
      "properties": {
        "probe_sequence": {
          "type": "integer",
          "minimum": 1
        },
        "probe_nonce": {
          "$ref": "#/$defs/non_empty_string"
        },
        "probe_request_issued_at_utc": {
          "type": "string",
          "format": "date-time"
        },
        "probe_request_expires_at_utc": {
          "type": "string",
          "format": "date-time"
        },
        "probe_ack_at_utc": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "bridge_registration_path": {
          "$ref": "#/$defs/non_empty_string"
        },
        "bridge_registration_sha256": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^[a-f0-9]{64}$"
        },
        "probe_request_sha256": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^[a-f0-9]{64}$"
        },
        "probe_ack_sha256": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^[a-f0-9]{64}$"
        }
      }
    },
    "active_stage": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": false,
      "required": [
        "stage_name",
        "item_id",
        "attempt_number",
        "child_tool",
        "child_pid",
        "child_command",
        "started_at_utc",
        "active_stage_path",
        "active_stage_sha256"
      ],
      "properties": {
        "stage_name": {
          "$ref": "#/$defs/non_empty_string"
        },
        "item_id": {
          "$ref": "#/$defs/identifier"
        },
        "attempt_number": {
          "type": "integer",
          "minimum": 1
        },
        "child_tool": {
          "$ref": "#/$defs/non_empty_string"
        },
        "child_pid": {
          "type": "integer",
          "minimum": 1
        },
        "child_command": {
          "type": [
            "string",
            "null"
          ]
        },
        "started_at_utc": {
          "type": "string",
          "format": "date-time"
        },
        "active_stage_path": {
          "$ref": "#/$defs/non_empty_string"
        },
        "active_stage_sha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "diagnosis_snapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kernel_status_level",
        "pending_action_kind",
        "recoverability_class",
        "next_supervisor_action"
      ],
      "properties": {
        "kernel_status_level": {
          "type": [
            "string",
            "null"
          ]
        },
        "pending_action_kind": {
          "type": [
            "string",
            "null"
          ]
        },
        "recoverability_class": {
          "type": [
            "string",
            "null"
          ]
        },
        "next_supervisor_action": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "rejection_reason": {
      "type": [
        "string",
        "null"
      ]
    },
    "latest_intervention_path": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    }
  }
}
