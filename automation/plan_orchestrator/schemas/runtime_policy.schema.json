{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:plan-orchestrator:schema:runtime_policy.v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "resolved_at_utc",
    "repo_control_plane_path",
    "overlay_control_plane_path",
    "sources",
    "options"
  ],
  "properties": {
    "schema_version": {
      "const": "plan_orchestrator.runtime_policy.v1"
    },
    "resolved_at_utc": {
      "type": "string",
      "format": "date-time"
    },
    "repo_control_plane_path": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "overlay_control_plane_path": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "sources": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "codex_model",
        "codex_reasoning_effort",
        "claude_model",
        "claude_effort",
        "auto_advance",
        "max_items",
        "max_fix_rounds",
        "max_remediation_rounds",
        "execution_timeout_sec",
        "verification_timeout_sec",
        "audit_timeout_sec",
        "triage_timeout_sec",
        "fix_timeout_sec",
        "remediation_timeout_sec"
      ],
      "properties": {
        "codex_model": {
          "$ref": "#/$defs/runtime_policy_source"
        },
        "codex_reasoning_effort": {
          "$ref": "#/$defs/runtime_policy_source"
        },
        "claude_model": {
          "$ref": "#/$defs/runtime_policy_source"
        },
        "claude_effort": {
          "$ref": "#/$defs/runtime_policy_source"
        },
        "auto_advance": {
          "$ref": "#/$defs/runtime_policy_source"
        },
        "max_items": {
          "$ref": "#/$defs/runtime_policy_source"
        },
        "max_fix_rounds": {
          "$ref": "#/$defs/runtime_policy_source"
        },
        "max_remediation_rounds": {
          "$ref": "#/$defs/runtime_policy_source"
        },
        "execution_timeout_sec": {
          "$ref": "#/$defs/runtime_policy_source"
        },
        "verification_timeout_sec": {
          "$ref": "#/$defs/runtime_policy_source"
        },
        "audit_timeout_sec": {
          "$ref": "#/$defs/runtime_policy_source"
        },
        "triage_timeout_sec": {
          "$ref": "#/$defs/runtime_policy_source"
        },
        "fix_timeout_sec": {
          "$ref": "#/$defs/runtime_policy_source"
        },
        "remediation_timeout_sec": {
          "$ref": "#/$defs/runtime_policy_source"
        }
      }
    },
    "options": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "codex_model",
        "codex_reasoning_effort",
        "claude_model",
        "claude_effort",
        "auto_advance",
        "max_items",
        "max_fix_rounds",
        "max_remediation_rounds",
        "execution_timeout_sec",
        "verification_timeout_sec",
        "audit_timeout_sec",
        "triage_timeout_sec",
        "fix_timeout_sec",
        "remediation_timeout_sec"
      ],
      "properties": {
        "codex_model": {
          "type": "string",
          "minLength": 1
        },
        "codex_reasoning_effort": {
          "enum": [
            "minimal",
            "low",
            "medium",
            "high",
            "xhigh"
          ]
        },
        "claude_model": {
          "type": "string",
          "minLength": 1
        },
        "claude_effort": {
          "enum": [
            "low",
            "medium",
            "high",
            "max"
          ]
        },
        "auto_advance": {
          "type": "boolean"
        },
        "max_items": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1
        },
        "max_fix_rounds": {
          "type": "integer",
          "minimum": 0
        },
        "max_remediation_rounds": {
          "type": "integer",
          "minimum": 0
        },
        "execution_timeout_sec": {
          "type": "integer",
          "minimum": 1
        },
        "verification_timeout_sec": {
          "type": "integer",
          "minimum": 1
        },
        "audit_timeout_sec": {
          "type": "integer",
          "minimum": 1
        },
        "triage_timeout_sec": {
          "type": "integer",
          "minimum": 1
        },
        "fix_timeout_sec": {
          "type": "integer",
          "minimum": 1
        },
        "remediation_timeout_sec": {
          "type": "integer",
          "minimum": 1
        }
      }
    }
  },
  "$defs": {
    "runtime_policy_source": {
      "enum": [
        "default",
        "repo_config",
        "config_file",
        "env",
        "cli"
      ]
    }
  }
}
